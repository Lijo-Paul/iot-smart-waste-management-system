#define IR_PIN 19

void setup() {
  Serial.begin(115200);
  pinMode(IR_PIN, INPUT);

  Serial.println("IR Sensor Test Started");
}

void loop() {

  int irValue = digitalRead(IR_PIN);

  if (irValue == LOW) {
    Serial.println("Object Detected");
  } else {
    Serial.println("No Object");
  }

  delay(500);
}
